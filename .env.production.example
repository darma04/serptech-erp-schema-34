# ==========================================================================
# SERPTECH — Production Environment Variables (.env)
# ==========================================================================
# Copy file ini ke .env dan sesuaikan nilai-nilainya.
# JANGAN commit file .env ke repository!
# ==========================================================================

# --- Core Django ---
DEBUG=False
DJANGO_ENVIRONMENT=production
SECRET_KEY=GANTI_DENGAN_RANDOM_KEY_50_KARAKTER

# --- Domain & Hosts ---
# Wildcard subdomain: .serptech.serpgroup.cloud mencocokkan semua *.serptech.serpgroup.cloud
ALLOWED_HOSTS=.serptech.serpgroup.cloud,.serpgroup.cloud
CSRF_TRUSTED_ORIGINS=https://*.serptech.serpgroup.cloud,https://serptech.serpgroup.cloud
BASE_URL=https://serptech.serpgroup.cloud

# Cookie domain — agar session berlaku untuk semua subdomain tenant
# Dot prefix (.domain) berarti cookie berlaku untuk domain DAN semua subdomain
SESSION_COOKIE_DOMAIN=.serptech.serpgroup.cloud

# --- PostgreSQL Database ---
DATABASE_ENGINE=postgresql
DATABASE_NAME=serptech_db
DATABASE_USER=serptech_user
DATABASE_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT
DATABASE_HOST=localhost
DATABASE_PORT=5432

# --- CLS (Central License Server) Connection ---
LICENSE_SERVER_URL=https://cls.serpgroup.cloud

# --- Internal API Key (untuk komunikasi dengan CLS) ---
# CLS menggunakan key ini untuk mengelola tenant via API
SAAS_INTERNAL_API_KEY=GANTI_DENGAN_RANDOM_API_KEY

# --- Device Identity ---
DEVICE_NAME=SERPTECH Production Server
